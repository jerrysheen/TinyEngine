		{"id":"fbfbe433a1fb14c7","type":"text","text":"# AcqureFrame\n等待这一帧可复用\n","x":1095,"y":510,"width":365,"height":80},
		{"id":"05b001eb6131f761","type":"text","text":"# ApplyDelta\n更新这一帧的脏数据到 GPUScene和CPUScene中\n","x":1095,"y":629,"width":365,"height":131},
		{"id":"dccef7e84bafc1fa","type":"text","text":"# BuildUploadPlan\nUploadPlan uploadPlan = mGPUWorld.BuildUploadPlan(fc\n包含 object/aabb/proxybuffer/visibility/indirect args的初始化请求\n只生成，直接submit也行\n","x":1095,"y":799,"width":595,"height":148},
		{"id":"f7f6ca56304dc93a","type":"text","text":"# BuildRenderContext\n准备一个 RenderContext， 里面包含各种View等， 等会来完善\n","x":1095,"y":980,"width":595,"height":148},
		{"id":"56a066b13b4e9d6b","type":"text","text":"# RecordFramePacket\nFramePacket packet\nmPipeline->Prepare(buildCtx)\nmPipeline->Record(paket, buildCtx\nmPipeline->Submit();\n","x":1095,"y":1180,"width":595,"height":200},
