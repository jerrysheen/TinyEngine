{
  "task_id": "example-task",
  "title": "示例任务",
  "max_step_retries": 2,
  "notes": [
    "current_step 不写在 task.json，运行态游标只在 _ai/runs/<task-id>/progress.json 中维护。",
    "Python verifier 还有代码级硬上限；即使这里写得更大，也会被截断。",
    "如果 step 会生成文本文件，建议在写完后运行 python .harness/scripts/stamp_provenance.py <path> 写入任务追踪头注释。"
  ],
  "steps": [
    {
      "id": "analyze",
      "title": "确认目标文件存在",
      "acceptance": {
        "type": "files_exist",
        "files": [
          "Runtime/Renderer"
        ]
      }
    },
    {
      "id": "implement",
      "title": "完成指定文件修改",
      "acceptance": {
        "type": "changed_files",
        "files": [
          "Runtime/Renderer/Example.cpp"
        ]
      }
    },
    {
      "id": "build",
      "title": "完成 Debug x64 构建",
      "acceptance": {
        "type": "msbuild",
        "solution": "Projects/Windows/Visual Studio 2022/TinyEngine.sln",
        "configuration": "Debug",
        "platform": "x64",
        "generate_projects": true
      }
    }
  ]
}
