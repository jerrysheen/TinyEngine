    "ignore_dirs": [
      "bin", "build", "out", ".git", ".vs", ".vscode", ".cursor",
      "_ai",
      "Vendor", "Projects",
      "Runtime/External", "Runtime/Docs", "Runtime/Examples",
      "Tools", "Docs", "Note",
